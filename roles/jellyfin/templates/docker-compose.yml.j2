services:
  jellyfin:
    image: jellyfin/jellyfin
    container_name: jellyfin
    volumes:
      - config:/config
      - cache:/cache
      - media:/media
      - media2:/media2
    restart: 'unless-stopped'
    ports:
      - "8096:8096"
volumes:
  config: {}
  cache: {}
  media: {}
  media2: {}