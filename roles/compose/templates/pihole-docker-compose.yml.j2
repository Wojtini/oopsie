services:
  pihole:
    container_name: pihole
    image: {{ pihole_image }}
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "67:67/udp"
      - "8085:80/tcp"
    environment:
      TZ: 'Europe/Warsaw'
      WEBPASSWORD: 'mateusz'
    volumes:
      - pihole:/etc/pihole
      - dnsmasq:/etc/dnsmasq.d
    cap_add:
      - NET_ADMIN
    restart: unless-stopped

volumes:
  pihole: {}
  dnsmasq: {}
